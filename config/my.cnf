# ============================================================================
# MariaDB Configuration for SQL Tuning Playground (Learning Environment)
# ============================================================================
# This file configures MariaDB for the SQL tuning learning exercises.
# These are NOT production settings—they're optimized for education.
#
# Usage: Mounted into Docker container at /config/custom.cnf
# ============================================================================

[mysqld]
# ============================================================================
# InnoDB Buffer Pool (Most Important for Performance)
# ============================================================================
# Set to ~80% of available RAM for learning environment
# Production: Usually 80% of system RAM
innodb_buffer_pool_size = 512M

# ============================================================================
# Connection Settings
# ============================================================================
# Max concurrent connections (learning environment)
# Production: Usually 150-500 depending on workload
max_connections = 200

# Threads to cache for new connections
thread_cache_size = 10

# ============================================================================
# Query Performance & Optimization
# ============================================================================
# Enable slow query log (useful for learning)
slow_query_log = 1
slow_query_log_file = /config/log/slow-query.log
long_query_time = 1

# Show queries without indexes (learning)
log_queries_not_using_indexes = 1

# ============================================================================
# Logging
# ============================================================================
# log_error_verbosity is MySQL-specific; MariaDB uses log_warnings instead
log_warnings = 2

# ============================================================================
# Binary Logging (Disabled for Learning)
# ============================================================================
# skip_log_bin

# ============================================================================
# Character Set & Collation
# ============================================================================
character_set_server = utf8mb4
collation_server = utf8mb4_unicode_ci
